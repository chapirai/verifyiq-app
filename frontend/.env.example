# Copy this file to .env.local for local development
# For Docker, the value is injected via docker-compose.yml

# URL of the backend API (must be reachable from the browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# Bolagsverket / HVD: no client secrets or dokumentId in env — the browser only talks to your API;
# the backend uses BV_* from the server .env (dokumentId always comes from dokumentlista per lookup).
