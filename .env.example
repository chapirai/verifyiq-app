NODE_ENV=production
PORT=4000

# ===== DATABASE (Render PostgreSQL) =====
# Use Render PostgreSQL "Internal" values for backend <-> DB connection.
# Keep both DATABASE_URL and PG_* populated because the app validates PG_* directly.
PG_HOST=<<<RENDER_DB_INTERNAL_HOST>>>
PG_PORT=5432
PG_DBNAME=<<<RENDER_DB_NAME>>>
PG_USER=<<<RENDER_DB_USER>>>
PG_PASSWORD=<<<RENDER_DB_PASSWORD>>>
DATABASE_URL=<<<RENDER_DB_INTERNAL_DATABASE_URL>>>

# ===== REDIS (required) =====
# If using Render Redis, copy the internal host/port/password from that service.
REDIS_HOST=<<<RENDER_REDIS_HOST>>>
REDIS_PORT=6379
REDIS_PASSWORD=<<<REDIS_PASSWORD>>>

# ===== FILE STORAGE (required: MinIO or S3-compatible) =====
MINIO_ENDPOINT=<<<MINIO_ENDPOINT>>>
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_REGION=eu-west-1
MINIO_ROOT_USER=<<<MINIO_ROOT_USER>>>
MINIO_ROOT_PASSWORD=<<<MINIO_ROOT_PASSWORD>>>
AWS_ACCESS_KEY_ID=<<<AWS_ACCESS_KEY_ID>>>
AWS_SECRET_ACCESS_KEY=<<<AWS_SECRET_ACCESS_KEY>>>
S3_BUCKET=verifyiq-documents

# ===== JWT =====
JWT_SECRET=<<<JWT_SECRET>>>
JWT_REFRESH_SECRET=<<<JWT_REFRESH_SECRET>>>
INTEGRATION_TOKEN_ENCRYPTION_KEY=<<<OPTIONAL_BUT_RECOMMENDED_16+_CHARS>>>

# ===== BOLAGSVERKET (shared OAuth client) =====
# Used for HVD unless you set BV_HVD_CLIENT_ID / BV_HVD_CLIENT_SECRET below.
# Values come from your Bolagsverket API customer registration (production or accept).
BV_CLIENT_ID=<<<BOLAGSVERKET_CLIENT_ID>>>
BV_CLIENT_SECRET=<<<BOLAGSVERKET_CLIENT_SECRET>>>

# ===== HVD — Värdefulla datamängder (production defaults filled in) =====
# Server-only OAuth: token from BV_HVD_TOKEN_URL using client credentials; cached automatically.
#
# Annual reports — no env per company and no manual dokumentId:
#   • Each company lookup runs POST …/dokumentlista; Bolagsverket returns dokument[] with a unique dokumentId per listed file.
#   • Download is GET …/dokument/{dokumentId} using only ids from that response (ids differ by company and by document).
#   • Do not set BV_HVD_DOCUMENT_PATH (removed); download path is always …/dokument/{dokumentId} under BV_HVD_BASE_URL.
#
BV_HVD_BASE_URL=https://gw.api.bolagsverket.se/vardefulla-datamangder/v1
BV_HVD_TOKEN_URL=https://portal.api.bolagsverket.se/oauth2/token
BV_HVD_REVOKE_URL=https://portal.api.bolagsverket.se/oauth2/revoke
BV_HVD_SCOPES=vardefulla-datamangder:read vardefulla-datamangder:ping
#
# Optional: dedicated HVD OAuth client (otherwise BV_CLIENT_ID / BV_CLIENT_SECRET are used)
# BV_HVD_CLIENT_ID=<<<OPTIONAL_HVD_ONLY_CLIENT_ID>>>
# BV_HVD_CLIENT_SECRET=<<<OPTIONAL_HVD_ONLY_CLIENT_SECRET>>>
#
# Bolagsverket accept / test — replace the four values above if your keys are for accept2:
# BV_HVD_BASE_URL=https://gw.api.bolagsverket.se/vardefulla-datamangder/v1
# BV_HVD_TOKEN_URL=https://portal-accept2.api.bolagsverket.se/oauth2/token
# BV_HVD_REVOKE_URL=https://portal-accept2.api.bolagsverket.se/oauth2/revoke
# BV_HVD_SCOPES=vardefulla-datamangder:read vardefulla-datamangder:ping

# ===== Företagsinformation =====
# OAuth mode (recommended) – set USE_OAUTH=true and provide separate credentials.
# The backend will automatically fetch and cache the token; you never manage it manually.
BV_FORETAGSINFO_BASE_URL=https://gw.api.bolagsverket.se/foretagsinformation/v4
BV_FORETAGSINFO_USE_OAUTH=true
BV_FORETAGSINFO_CLIENT_ID=<<<BV_FORETAGSINFO_CLIENT_ID>>>
BV_FORETAGSINFO_CLIENT_SECRET=<<<BV_FORETAGSINFO_CLIENT_SECRET>>>
BV_FORETAGSINFO_TOKEN_URL=<<<BV_FORETAGSINFO_TOKEN_URL>>>
BV_FORETAGSINFO_SCOPES=<<<OPTIONAL_FORETAGSINFO_SCOPES>>>
# Legacy static-token fallback (only if OAuth is not available):
# BV_FORETAGSINFO_AUTH_HEADER=Authorization
# BV_FORETAGSINFO_AUTH_VALUE=Bearer <<<TOKEN>>>
# BV_FORETAGSINFO_BEARER_TOKEN=<<<OPTIONAL_BEARER_TOKEN>>>

# ===== DEPLOYMENT URLS =====
# Backend (Render web service public URL + /api/v1)
API_BASE_URL=https://<<<YOUR_RENDER_BACKEND_SERVICE>>>.onrender.com/api/v1

# Backend CORS allow-list (your Vercel frontend production URL at minimum)
FRONTEND_URL=https://<<<YOUR_VERCEL_PROJECT>>>.vercel.app
# Optional extra allowed origins (comma-separated), e.g. custom domain + Vercel preview domain
FRONTEND_URLS=https://<<<YOUR_CUSTOM_DOMAIN>>>,https://<<<YOUR_VERCEL_PROJECT>>>.vercel.app

# Frontend (set in Vercel project env vars)
NEXT_PUBLIC_API_BASE_URL=https://<<<YOUR_RENDER_BACKEND_SERVICE>>>.onrender.com/api/v1
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=demo-bank
