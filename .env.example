NODE_ENV=development
PORT=4000

PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=Company
PG_USER=postgres
PG_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/Company

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
# Set true only for local/dev environments that run Redis < 5 (e.g. older Windows builds)
BULLMQ_SKIP_REDIS_VERSION_CHECK=false

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_REGION=eu-west-1
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=verifyiq-documents

JWT_SECRET=WZ68qSjcW6YNHkHetT39/vBJFmKrzzr53iv+nFpxm5Y=
JWT_REFRESH_SECRET=uppyoy6DH7cb/nO5wdEdELl8FgDlhF9qWxugzQmzta4=
# Optional dedicated key for integration token encryption at rest.
# If empty, backend falls back to JWT_SECRET.
INTEGRATION_TOKEN_ENCRYPTION_KEY=

# ============================================
# BOLAGSVERKET (Swedish Companies Registry API)
# ============================================
BV_CLIENT_ID=replace-with-bolagsverket-client-id
BV_CLIENT_SECRET=replace-with-bolagsverket-client-secret

# Värdefulla Datamängder (OAuth2 Client Credentials)
BV_HVD_CLIENT_ID=
BV_HVD_CLIENT_SECRET=
BV_HVD_BASE_URL=https://gw.api.bolagsverket.se/vardefulla-datamangder/v1
# Optional override. Leave empty to use: ${BV_HVD_BASE_URL}/oauth2/token
BV_HVD_TOKEN_URL=
BV_HVD_REVOKE_URL=
BV_HVD_SCOPES=vardefulla-datamangder:read vardefulla-datamangder:ping
BV_HVD_DOCUMENT_PATH=/dokument

# Företagsinformation (Bearer / configurable auth)
BV_FORETAGSINFO_BASE_URL=https://gw.api.bolagsverket.se/foretagsinformation/v4
# Optional OAuth mode for Företagsinformation (disabled by default)
BV_FORETAGSINFO_USE_OAUTH=false
BV_FORETAGSINFO_TOKEN_URL=
BV_FORETAGSINFO_SCOPES=
BV_FORETAGSINFO_CLIENT_ID=
BV_FORETAGSINFO_CLIENT_SECRET=
BV_FORETAGSINFO_BEARER_TOKEN=
# Backward-compatible aliases accepted by backend:
# BV_FORETAGSINFO_AUTH_TOKEN=
# BV_FORETAGSINFO_TOKEN=
BV_FORETAGSINFO_AUTH_HEADER=Authorization
BV_FORETAGSINFO_AUTH_VALUE=


API_BASE_URL=http://localhost:4000/api/v1
FRONTEND_URL=http://localhost:3000
# Optional comma-separated list of additional allowed frontend origins for CORS.
# Example: https://nordiccompanydata.com,https://www.nordiccompanydata.com
FRONTEND_URLS=
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
