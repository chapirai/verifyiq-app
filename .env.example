# ============================================
# BOLAGSVERKET (Swedish Companies Registry API)
# ============================================
# Both APIs share the same OAuth2 token endpoint (portal.api.bolagsverket.se),
# which is separate from the data gateway (gw.api.bolagsverket.se).
# The token endpoint uses HTTP POST with HTTP Basic Auth credentials
# (Authorization header) and grant_type/scope as form body parameters.

# ── Shared / Legacy credentials ─────────────────────────────────────────────
# BV_CLIENT_ID and BV_CLIENT_SECRET are the legacy fallback.
# They are only used when no API-specific OAuth credentials are set.
BV_CLIENT_ID=replace-with-bolagsverket-client-id
BV_CLIENT_SECRET=replace-with-bolagsverket-client-secret

# ── Värdefulla Datamängder (OAuth2 Client Credentials) ──────────────────────
# Token URL: POST https://portal.api.bolagsverket.se/oauth2/token
#   Auth:    HTTP Basic Auth (Authorization: Basic base64(client_id:client_secret))
#   Body:    grant_type=client_credentials&scope=<scope>
# Data URL: POST https://gw.api.bolagsverket.se/vardefulla-datamangder/v1
BV_HVD_CLIENT_ID=
BV_HVD_CLIENT_SECRET=
BV_HVD_BASE_URL=https://gw.api.bolagsverket.se/vardefulla-datamangder/v1
# Token URL defaults to https://portal.api.bolagsverket.se/oauth2/token when not set
BV_HVD_TOKEN_URL=https://portal.api.bolagsverket.se/oauth2/token
BV_HVD_REVOKE_URL=
BV_HVD_SCOPES=vardefulla-datamangder:read vardefulla-datamangder:ping
BV_HVD_DOCUMENT_PATH=/dokument

# ── Företagsinformation (OAuth2 or Bearer) ───────────────────────────────────
# Token URL: same portal endpoint with foretagsinformation:read scope.
# Data URL:  POST https://gw.api.bolagsverket.se/foretagsinformation/v4/organisationsinformation
#
# Option A (recommended): OAuth2 – set client credentials below.
#   If BV_FORETAGSINFO_CLIENT_ID / BV_HVD_CLIENT_ID is set, the app will
#   automatically fetch & cache a token with the foretagsinformation:read scope.
BV_FORETAGSINFO_CLIENT_ID=
BV_FORETAGSINFO_CLIENT_SECRET=
# Token URL defaults to BV_HVD_TOKEN_URL → https://portal.api.bolagsverket.se/oauth2/token
BV_FORETAGSINFO_TOKEN_URL=
BV_FORETAGSINFO_SCOPE=foretagsinformation:read
#
# Option B: Static Bearer token (set this if you have a long-lived token).
BV_FORETAGSINFO_BASE_URL=https://gw.api.bolagsverket.se/foretagsinformation/v4
BV_FORETAGSINFO_BEARER_TOKEN=
# Option C: Custom auth header (for non-Bearer auth schemes).
BV_FORETAGSINFO_AUTH_HEADER=Authorization
BV_FORETAGSINFO_AUTH_VALUE=


API_BASE_URL=http://localhost:4000/api/v1
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
